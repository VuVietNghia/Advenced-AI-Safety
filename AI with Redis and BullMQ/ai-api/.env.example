# Server
PORT=3000
NODE_ENV=development

# Redis (Docker)
REDIS_HOST=localhost
REDIS_PORT=6379

# SQL Server
MSSQL_HOST=localhost
MSSQL_PORT=1433
MSSQL_USER=sa
MSSQL_PASSWORD=your_password_here
MSSQL_DATABASE=ai_api_logs

# AI Proxy (GLM — Anthropic-compatible)
ANTHROPIC_BASE_URL=https://llm-hub.roxane.one
ANTHROPIC_AUTH_TOKEN=your_token_here
ANTHROPIC_MODEL=glm-4.6

# Cache TTL (seconds)
CACHE_TTL=300

# Worker
MAX_TOOL_ROUNDS=10
JOB_TIMEOUT_MS=300000
WORKER_CONCURRENCY=3
